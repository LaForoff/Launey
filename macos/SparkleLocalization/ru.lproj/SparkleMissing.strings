"%1$@ %2$@ has been downloaded and is ready to use! This is an important update; would you like to install it and relaunch %1$@ now?" = "Важное обновление %1$@ версии %2$@ загружено и готово к использованию. Установить его и перезапустить %1$@ сейчас?";
"%1$@ %2$@ is available but this update requires a new Apple silicon Mac." = "Версия %1$@ %2$@ доступна, но для этого обновления требуется новый Mac с Apple silicon.";
"%1$@ %2$@ is available but your macOS version is too new for this update. This update only supports up to macOS %3$@." = "Версия %1$@ %2$@ доступна, но ваша версия macOS слишком новая для этого обновления. Поддерживается macOS не новее %3$@.";
"%1$@ %2$@ is available but your macOS version is too old to install it. At least macOS %3$@ is required." = "Версия %1$@ %2$@ доступна, но ваша версия macOS слишком старая для её установки. Требуется macOS %3$@ или новее.";
"%1$@ can’t be updated if it’s running from the location it was downloaded to." = "%1$@ нельзя обновить, пока приложение запущено из папки загрузки.";
"%@ %@ is now available—you have %@. This is an important update; would you like to download it now?" = "Доступно важное обновление %1$@ %2$@ — у вас установлена версия %3$@. Загрузить его сейчас?";
"%@ %@ is now available—you have %@. Would you like to learn more about this update on the web?" = "Доступна версия %1$@ %2$@ — у вас установлена версия %3$@. Узнать больше об этом обновлении в интернете?";
"%@ is now updated to version %@!" = "%1$@ обновлено до версии %2$@!";
"%@ is now updated!" = "%@ обновлено!";
